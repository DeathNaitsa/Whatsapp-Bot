# Environment Variables Example
# Kopiere diese Datei zu .env und fülle die Werte aus

# ========================================
# Datenbank
# ========================================
# Optional: Datenbank-Passwort (wird sonst beim Start abgefragt)
# DB_PASSWORD=dein-sicheres-passwort-hier

# ========================================
# Web-Interface Secrets
# ========================================
# WICHTIG: Ändere diese Secrets! 
# Generiere sichere Secrets mit: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Session Secret für Express Sessions
SESSION_SECRET=ÄNDERE-DIES-GENERIERE-EINEN-ZUFÄLLIGEN-STRING

# JWT Secret für Token-Authentifizierung
JWT_SECRET=ÄNDERE-DIES-GENERIERE-EINEN-ANDEREN-ZUFÄLLIGEN-STRING

# ========================================
# Node Environment
# ========================================
# production, development, test
NODE_ENV=development

# ========================================
# Optional: Externe Services
# ========================================
# Falls du externe APIs verwendest
# API_KEY=dein-api-key
# WEBHOOK_URL=https://example.com/webhook
